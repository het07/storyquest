# ---------------------------------------------------------------------------
# StoryQuest Arena — environment variables
# Copy this file to `.env.local` and fill in your own values.
# NEVER commit `.env.local`. This `.env.example` is safe to commit (no secrets).
# ---------------------------------------------------------------------------

# --- Supabase (Database + Auth) --- [added in Phase 2]
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key           # SERVER ONLY — never expose to client

# --- Prisma (Supabase Postgres connection strings) --- [added in Phase 2]
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-region.pooler.supabase.com:5432/postgres

# --- Exa AI --- [added in Phase 3]
# EXA_API_KEY=your_exa_api_key                              # https://dashboard.exa.ai

# --- Google Gemini (free fallback) --- [added in Phase 3]
# GEMINI_API_KEY=your_gemini_api_key                        # https://aistudio.google.com/apikey

# --- ElevenLabs TTS --- [added in Phase 5]
# ELEVENLABS_API_KEY=your_elevenlabs_key                    # https://elevenlabs.io/app/settings/api-keys
# ELEVENLABS_VOICE_ID=your_voice_id

# --- Wispr Flow STT --- [added in Phase 5]
# WISPR_API_KEY=your_wispr_api_key
# NEXT_PUBLIC_WISPR_ENABLED=true

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
