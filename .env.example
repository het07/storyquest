# ---------------------------------------------------------------------------
# StoryQuest Arena — environment variables
# Copy this file to `.env.local` and fill in your own values.
# NEVER commit `.env.local`. This `.env.example` is safe to commit (no secrets).
# ---------------------------------------------------------------------------

# --- MongoDB (Database) ---
# From MongoDB Atlas: Database > Connect > Drivers. URL-encode special chars in the password.
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=storyquest                                        # database name (any name)

# --- Auth.js / NextAuth (Google OAuth + guest mode) ---
AUTH_SECRET=generate_with_npx_auth_secret                    # run: npx auth secret
# Google OAuth: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret

# --- Exa AI ---
EXA_API_KEY=your_exa_api_key                                # https://dashboard.exa.ai

# --- Google Gemini (free fallback + quiz generation) ---
GEMINI_API_KEY=your_gemini_api_key                          # https://aistudio.google.com/apikey
# GEMINI_MODEL=gemini-2.5-flash                             # optional override (free-tier model)

# --- ElevenLabs TTS --- [added in Phase 5]
# ELEVENLABS_API_KEY=your_elevenlabs_key                    # https://elevenlabs.io/app/settings/api-keys
# ELEVENLABS_VOICE_ID=your_voice_id

# --- Wispr Flow STT --- [added in Phase 5]
# WISPR_API_KEY=your_wispr_api_key
# NEXT_PUBLIC_WISPR_ENABLED=true

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
